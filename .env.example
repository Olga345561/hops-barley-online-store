# Django
SECRET_KEY=change-me-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (docker compose passes POSTGRES_HOST=db)
DB_ENGINE=postgres
POSTGRES_DB=shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email (console backend prints emails to stdout)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=shop@hopandbarley.example
ORDER_NOTIFICATION_EMAIL=admin@hopandbarley.examplev